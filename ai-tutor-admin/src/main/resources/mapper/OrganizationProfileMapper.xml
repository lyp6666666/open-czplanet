<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.admin.mapper.OrganizationProfileMapper">

    <resultMap id="OrganizationProfileMap" type="com.ai.tutor.admin.model.entity.OrganizationProfile">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="org_name" property="orgName"/>
        <result column="intro" property="intro"/>
        <result column="contact_name" property="contactName"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="address" property="address"/>
        <result column="license_no" property="licenseNo"/>
        <result column="split_platform_percent" property="splitPlatformPercent"/>
        <result column="split_org_percent" property="splitOrgPercent"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByUserId" parameterType="long" resultMap="OrganizationProfileMap">
        SELECT *
        FROM organization_profile
        WHERE user_id = #{userId}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.ai.tutor.admin.model.entity.OrganizationProfile"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO organization_profile (
            user_id, org_name, intro, contact_name, contact_phone, address, license_no,
            split_platform_percent, split_org_percent, status, create_time, update_time
        ) VALUES (
            #{userId}, #{orgName}, #{intro}, #{contactName}, #{contactPhone}, #{address}, #{licenseNo},
            #{splitPlatformPercent}, #{splitOrgPercent}, #{status}, #{createTime}, #{updateTime}
        )
    </insert>

</mapper>
