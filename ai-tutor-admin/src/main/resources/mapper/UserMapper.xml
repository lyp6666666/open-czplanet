<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.admin.mapper.UserMapper">

    <resultMap id="BaseUserResultMap" type="com.ai.tutor.admin.model.entity.User">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="avatar" column="avatar"/>
        <result property="sex" column="sex"/>
        <result property="openId" column="open_id"/>
        <result property="phone" column="phone"/>
        <result property="activeStatus" column="active_status"/>
        <result property="lastOptTime" column="last_opt_time"/>
        <result property="ipInfo" column="ip_info" jdbcType="VARCHAR"/>
        <result property="itemId" column="item_id"/>
        <result property="status" column="status"/>
        <result property="refId" column="ref_id"/>
        <result property="userType" column="user_type"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <update id="updateUserBaseInfo" parameterType="com.ai.tutor.admin.model.dto.user.BaseUserInfo">
        UPDATE user
        <set>
            <if test="userInfo.name != null">
                name = #{userInfo.name},
            </if>
            <if test="userInfo.avatar != null">
                avatar = #{userInfo.avatar},
            </if>
            <if test="userInfo.sex != null">
                sex = #{userInfo.sex},
            </if>
            <if test="userInfo.activeStatus != null">
                active_status = #{userInfo.activeStatus},
            </if>
            <if test="userInfo.ipInfo != null">
                ip_info = #{userInfo.ipInfo},
            </if>
            <if test="userInfo.itemId != null">
                item_id = #{userInfo.itemId},
            </if>
            <if test="userInfo.status != null">
                status = #{userInfo.status},
            </if>
            update_time = now()
        </set>
        where id = #{id}
    </update>

    <select id="selectByPhoneAndUserType" parameterType="map" resultMap="BaseUserResultMap">
        SELECT * FROM user
        WHERE phone = #{phone}
          AND user_type = #{userType}
        LIMIT 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (
            name,
            phone,
            avatar,
            sex,
            open_id,
            active_status,
            last_opt_time,
            ip_info,
            item_id,
            status,
            user_type,
            ref_id,
            create_time,
            update_time
        )
        VALUES (
            #{name},
            #{phone},
            #{avatar},
            #{sex},
            #{openId},
            #{activeStatus},
            #{lastOptTime},
            #{ipInfo},
            #{itemId},
            #{status},
            #{userType},
            #{refId},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <select id="selectByIds" resultMap="BaseUserResultMap">
        SELECT *
        FROM user
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

</mapper>
