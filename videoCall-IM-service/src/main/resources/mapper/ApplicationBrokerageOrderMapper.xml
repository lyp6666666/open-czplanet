<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.videocallimservice.chat.mapper.ApplicationBrokerageOrderMapper">

    <resultMap id="baseMap" type="com.ai.tutor.videocallimservice.chat.domain.entity.ApplicationBrokerageOrder">
        <id column="id" property="id"/>
        <result column="application_id" property="applicationId"/>
        <result column="order_id" property="orderId"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ai.tutor.videocallimservice.chat.domain.entity.ApplicationBrokerageOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO application_brokerage_order
        (
            application_id,
            order_id,
            create_time,
            update_time
        )
        VALUES
        (
            #{applicationId},
            #{orderId},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <select id="selectByApplicationId" resultMap="baseMap">
        SELECT
            id, application_id, order_id, create_time, update_time
        FROM application_brokerage_order
        WHERE application_id = #{applicationId}
        LIMIT 1
    </select>

    <select id="selectByOrderId" resultMap="baseMap">
        SELECT
            id, application_id, order_id, create_time, update_time
        FROM application_brokerage_order
        WHERE order_id = #{orderId}
        LIMIT 1
    </select>
</mapper>
