<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.videocallimservice.chat.mapper.ChatRealtimeEventMapper">

    <resultMap id="chatRealtimeEventMap" type="com.ai.tutor.videocallimservice.chat.domain.entity.ChatRealtimeEvent">
        <id column="event_id" property="eventId"/>
        <result column="target_uid" property="targetUid"/>
        <result column="event_type" property="eventType"/>
        <result column="biz_type" property="bizType"/>
        <result column="room_id" property="roomId"/>
        <result column="msg_id" property="msgId"/>
        <result column="occurred_at" property="occurredAt"/>
        <result column="payload_json" property="payloadJson"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insertEvent" parameterType="com.ai.tutor.videocallimservice.chat.domain.entity.ChatRealtimeEvent">
        INSERT INTO chat_realtime_event
        (
            event_id,
            target_uid,
            event_type,
            biz_type,
            room_id,
            msg_id,
            occurred_at,
            payload_json,
            create_time
        )
        VALUES
        (
            #{eventId},
            #{targetUid},
            #{eventType},
            #{bizType},
            #{roomId},
            #{msgId},
            #{occurredAt},
            #{payloadJson},
            NOW(3)
        )
    </insert>

    <select id="listAfter" resultMap="chatRealtimeEventMap">
        SELECT
            event_id,
            target_uid,
            event_type,
            biz_type,
            room_id,
            msg_id,
            occurred_at,
            payload_json,
            create_time
        FROM chat_realtime_event
        WHERE target_uid = #{targetUid}
          AND event_id &gt; #{lastEventId}
        ORDER BY event_id ASC
        LIMIT #{limit}
    </select>

    <select id="selectLatestEventId" resultType="java.lang.Long">
        SELECT MAX(event_id)
        FROM chat_realtime_event
        WHERE target_uid = #{targetUid}
    </select>

</mapper>
