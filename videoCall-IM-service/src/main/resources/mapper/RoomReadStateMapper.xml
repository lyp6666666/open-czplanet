<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.videocallimservice.chat.mapper.RoomReadStateMapper">

    <resultMap id="roomReadStateMap" type="com.ai.tutor.videocallimservice.chat.domain.entity.RoomReadState">
        <id column="id" property="id"/>
        <result column="room_id" property="roomId"/>
        <result column="uid" property="uid"/>
        <result column="last_read_msg_id" property="lastReadMsgId"/>
        <result column="last_read_time" property="lastReadTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="getByRoomAndUid" resultMap="roomReadStateMap">
        SELECT *
        FROM room_read_state
        WHERE room_id = #{roomId}
          AND uid = #{uid}
        LIMIT 1
    </select>

    <select id="listByRoomIdsAndUid" resultMap="roomReadStateMap">
        SELECT *
        FROM room_read_state
        WHERE uid = #{uid}
          AND room_id IN
        <foreach collection="roomIds" item="rid" open="(" separator="," close=")">
            #{rid}
        </foreach>
    </select>

    <insert id="upsertReadState">
        INSERT INTO room_read_state
        (
            room_id,
            uid,
            last_read_msg_id,
            last_read_time,
            create_time,
            update_time
        )
        VALUES
        (
            #{roomId},
            #{uid},
            #{lastReadMsgId},
            NOW(3),
            NOW(3),
            NOW(3)
        )
        ON DUPLICATE KEY UPDATE
            last_read_msg_id = GREATEST(IFNULL(last_read_msg_id, 0), VALUES(last_read_msg_id)),
            last_read_time = VALUES(last_read_time),
            update_time = VALUES(update_time)
    </insert>

</mapper>
