<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.videocallimservice.chat.mapper.MessageMapper">

    <resultMap id="cursorMap"
               type="com.ai.tutor.videocallimservice.chat.domain.entity.Message">
        <id column="id" property="id"/>
        <result column="room_id" property="roomId"/>
        <result column="from_uid" property="fromUid"/>
        <result column="to_uid" property="toUid"/>
        <result column="content" property="content"/>
        <result column="reply_msg_id" property="replyMsgId"/>
        <result column="status" property="status"/>
        <result column="gap_count" property="gapCount"/>
        <result column="type" property="type"/>
        <result column="extra" property="extra"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>


    <!-- 游标分页查询 -->
    <select id="getCursorPage"
            resultMap="cursorMap">
        SELECT
        id,
        room_id,
        from_uid,
        to_uid,
        content,
        reply_msg_id,
        status,
        gap_count,
        type,
        extra,
        create_time,
        update_time
        FROM message
        WHERE room_id = #{roomId}
        AND status = 0
        <if test="request.cursor != null">
            AND id &lt; #{request.cursor}
        </if>
        ORDER BY id DESC
        LIMIT #{request.pageSize}
    </select>


    <insert id="save"
            parameterType="com.ai.tutor.videocallimservice.chat.domain.entity.Message"
            useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO message
        (
            room_id,
            from_uid,
            to_uid,
            content,
            reply_msg_id,
            status,
            gap_count,
            type,
            extra,
            create_time,
            update_time
        )
        VALUES
            (
                #{roomId},
                #{fromUid},
                #{toUid},
                #{content},
                #{replyMsgId},
                #{status},
                #{gapCount},
                #{type},
                #{extra},
                #{createTime},
                #{updateTime}
            )
    </insert>


</mapper>