<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.TeacherSettlementMapper">

    <resultMap id="TeacherSettlementMap" type="com.ai.tutor.appointment.model.entity.TeacherSettlement">
        <id column="id" property="id"/>
        <result column="lesson_payment_order_id" property="lessonPaymentOrderId"/>
        <result column="teacher_uid" property="teacherUid"/>
        <result column="settlement_amount_fen" property="settlementAmountFen"/>
        <result column="platform_fee_amount_fen" property="platformFeeAmountFen"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insertIgnore" parameterType="com.ai.tutor.appointment.model.entity.TeacherSettlement">
        INSERT IGNORE INTO teacher_settlement
        (lesson_payment_order_id, teacher_uid, settlement_amount_fen, platform_fee_amount_fen, status)
        VALUES
        (#{lessonPaymentOrderId}, #{teacherUid}, #{settlementAmountFen}, #{platformFeeAmountFen}, #{status})
    </insert>

    <select id="selectByLessonPaymentOrderId" resultMap="TeacherSettlementMap">
        SELECT id, lesson_payment_order_id, teacher_uid, settlement_amount_fen, platform_fee_amount_fen,
               status, create_time, update_time
        FROM teacher_settlement
        WHERE lesson_payment_order_id = #{lessonPaymentOrderId}
        LIMIT 1
    </select>
</mapper>
