<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.InviteRewardRecordMapper">

    <resultMap id="InviteRewardRecordMap" type="com.ai.tutor.appointment.model.entity.InviteRewardRecord">
        <id column="id" property="id"/>
        <result column="inviter_uid" property="inviterUid"/>
        <result column="invitee_uid" property="inviteeUid"/>
        <result column="reward_scene" property="rewardScene"/>
        <result column="biz_order_type" property="bizOrderType"/>
        <result column="biz_order_id" property="bizOrderId"/>
        <result column="payment_order_id" property="paymentOrderId"/>
        <result column="base_amount_fen" property="baseAmountFen"/>
        <result column="reward_rate" property="rewardRate"/>
        <result column="reward_amount_fen" property="rewardAmountFen"/>
        <result column="status" property="status"/>
        <result column="freeze_reason" property="freezeReason"/>
        <result column="settlement_month" property="settlementMonth"/>
        <result column="config_snapshot_json" property="configSnapshotJson"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ai.tutor.appointment.model.entity.InviteRewardRecord" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO invite_reward_record
        (
            inviter_uid,
            invitee_uid,
            reward_scene,
            biz_order_type,
            biz_order_id,
            payment_order_id,
            base_amount_fen,
            reward_rate,
            reward_amount_fen,
            status,
            freeze_reason,
            settlement_month,
            config_snapshot_json,
            create_time,
            update_time
        )
        VALUES
        (
            #{inviterUid},
            #{inviteeUid},
            #{rewardScene},
            #{bizOrderType},
            #{bizOrderId},
            #{paymentOrderId},
            #{baseAmountFen},
            #{rewardRate},
            #{rewardAmountFen},
            #{status},
            #{freezeReason},
            #{settlementMonth},
            #{configSnapshotJson},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <select id="pageByInviterUid" resultMap="InviteRewardRecordMap">
        SELECT *
        FROM invite_reward_record
        WHERE inviter_uid = #{inviterUid}
        <if test="cursor != null">
            AND id &lt; #{cursor}
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        <if test="scene != null and scene != ''">
            AND reward_scene = #{scene}
        </if>
        ORDER BY id DESC
        LIMIT #{pageSize}
    </select>

    <update id="markSettlementPending">
        UPDATE invite_reward_record
        SET
            status = 'SETTLEMENT_PENDING',
            settlement_month = #{settlementMonth},
            update_time = NOW(3)
        WHERE inviter_uid = #{inviterUid}
          AND status IN ('PENDING', 'SETTLEABLE')
          AND create_time &lt; #{cutoff}
    </update>

</mapper>
