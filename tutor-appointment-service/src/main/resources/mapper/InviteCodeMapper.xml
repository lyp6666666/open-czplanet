<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.InviteCodeMapper">

    <resultMap id="InviteCodeMap" type="com.ai.tutor.appointment.model.entity.InviteCode">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="invite_code" property="inviteCode"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ai.tutor.appointment.model.entity.InviteCode" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO invite_code
        (
            user_id,
            invite_code,
            status,
            create_time,
            update_time
        )
        VALUES
        (
            #{userId},
            #{inviteCode},
            #{status},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <update id="updateInviteCodeByUserId">
        UPDATE invite_code
        SET invite_code = #{inviteCode},
            status = #{status},
            update_time = #{updateTime}
        WHERE user_id = #{userId}
    </update>

</mapper>
