<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.UserMapper">

    <resultMap id="UserMap" type="com.ai.tutor.appointment.model.entity.User">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="avatar" property="avatar"/>
        <result column="sex" property="sex"/>
        <result column="open_id" property="openId"/>
        <result column="phone" property="phone"/>
        <result column="user_type" property="userType"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="BaseUserResultMap" type="com.ai.tutor.appointment.model.entity.User">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="avatar" column="avatar"/>
        <result property="sex" column="sex"/>
        <result property="openId" column="open_id"/>
        <result property="activeStatus" column="active_status"/>
        <result property="lastOptTime" column="last_opt_time"/>
        <result property="ipInfo" column="ip_info" jdbcType="VARCHAR"/>
        <result property="itemId" column="item_id"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="userType" column="user_type"/>
    </resultMap>

    <select id="selectByPhoneAndUserType"
            parameterType="map"
            resultMap="BaseUserResultMap">
        SELECT * FROM user
        WHERE phone = #{phone}
          AND user_type = #{userType}
            LIMIT 1
    </select>


</mapper>