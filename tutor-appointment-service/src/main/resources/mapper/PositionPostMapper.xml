<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.PositionPostMapper">

    <resultMap id="PositionPostMap" type="com.ai.tutor.appointment.model.entity.PositionPost">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="name" property="name"/>
        <result column="grade" property="grade"/>
        <result column="description" property="description"/>
        <result column="sort" property="sort"/>
        <result column="enable_status" property="enableStatus"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectEnabledAll" resultMap="PositionPostMap">
        SELECT
            id,
            parent_id,
            name,
            grade,
            description,
            sort,
            enable_status,
            create_time,
            update_time
        FROM position_post
        WHERE enable_status = 1
        ORDER BY sort ASC, id ASC
    </select>

    <select id="searchEnabledByKeyword" resultMap="PositionPostMap">
        SELECT
            id,
            parent_id,
            name,
            grade,
            description,
            sort,
            enable_status,
            create_time,
            update_time
        FROM position_post
        WHERE enable_status = 1
          AND (name LIKE CONCAT('%', #{keyword}, '%') OR LOCATE(name, #{keyword}) > 0)
        ORDER BY sort ASC, id ASC
        LIMIT #{limit}
    </select>

    <select id="selectByIds" resultMap="PositionPostMap">
        SELECT
            id,
            parent_id,
            name,
            grade,
            description,
            sort,
            enable_status,
            create_time,
            update_time
        FROM position_post
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="selectFirstEnabledLeafId" resultType="long">
        SELECT p.id
        FROM position_post p
        LEFT JOIN position_post c
               ON c.parent_id = p.id
              AND c.enable_status = 1
        WHERE p.enable_status = 1
          AND c.id IS NULL
        ORDER BY p.sort ASC, p.id ASC
        LIMIT 1
    </select>

</mapper>
