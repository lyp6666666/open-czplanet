<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.InviteSettlementOrderMapper">

    <resultMap id="InviteSettlementOrderMap" type="com.ai.tutor.appointment.model.entity.InviteSettlementOrder">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="settlement_month" property="settlementMonth"/>
        <result column="total_amount_fen" property="totalAmountFen"/>
        <result column="paid_amount_fen" property="paidAmountFen"/>
        <result column="status" property="status"/>
        <result column="receiver_snapshot_json" property="receiverSnapshotJson"/>
        <result column="fail_reason" property="failReason"/>
        <result column="pay_time" property="payTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ai.tutor.appointment.model.entity.InviteSettlementOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO invite_settlement_order
        (
            user_id,
            settlement_month,
            total_amount_fen,
            paid_amount_fen,
            status,
            receiver_snapshot_json,
            fail_reason,
            pay_time,
            create_time,
            update_time
        )
        VALUES
        (
            #{userId},
            #{settlementMonth},
            #{totalAmountFen},
            #{paidAmountFen},
            #{status},
            #{receiverSnapshotJson},
            #{failReason},
            #{payTime},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <select id="pageByUserId" resultMap="InviteSettlementOrderMap">
        SELECT *
        FROM invite_settlement_order
        WHERE user_id = #{userId}
        <if test="cursor != null">
            AND id &lt; #{cursor}
        </if>
        ORDER BY id DESC
        LIMIT #{pageSize}
    </select>

</mapper>
