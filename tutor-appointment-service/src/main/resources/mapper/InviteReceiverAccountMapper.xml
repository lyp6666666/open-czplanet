<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ai.tutor.appointment.mapper.InviteReceiverAccountMapper">

    <resultMap id="InviteReceiverAccountMap" type="com.ai.tutor.appointment.model.entity.InviteReceiverAccount">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="receiver_name" property="receiverName"/>
        <result column="wechat_no" property="wechatNo"/>
        <result column="phone" property="phone"/>
        <result column="remark" property="remark"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.ai.tutor.appointment.model.entity.InviteReceiverAccount" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO invite_receiver_account
        (
            user_id,
            receiver_name,
            wechat_no,
            phone,
            remark,
            status,
            create_time,
            update_time
        )
        VALUES
        (
            #{userId},
            #{receiverName},
            #{wechatNo},
            #{phone},
            #{remark},
            #{status},
            #{createTime},
            #{updateTime}
        )
    </insert>

</mapper>
